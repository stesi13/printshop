// Catalog & inventory model — single source of truth for what we sell and
// how much of it we can produce. Read by the webshop and every marketplace
// integration (Etsy, eBay, …). See docs/catalog-model.md for the domain notes.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A Product is the customer-facing concept ("Hexagonal Planter").
// One Product has one or more Variants ("Small / Sage Green").
// Each Variant has exactly one SKU — the unit we list, sell, and ship.
model Product {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  description String
  status      ProductStatus   @default(draft)
  variants    ProductVariant[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum ProductStatus {
  draft
  active
  archived
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Human-readable variant name within a product, e.g. "Small / Sage Green".
  name      String
  // Variant-level options as JSON so we don't pre-commit to a fixed axes list.
  // Example: { "size": "small", "color": "sage-green" }
  options   Json    @default("{}")
  // Optional list price in minor units (cents). Falls back to product-level
  // pricing later if we add it; for now every variant prices itself.
  priceCents Int
  currency   String @default("USD")

  sku       Sku?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, name])
}

// SKU is the unit of inventory. One-to-one with Variant for now; we keep
// them as separate tables so kits/bundles can later point multiple variants
// at the same SKU or vice versa without a schema rewrite.
model Sku {
  id        String  @id @default(cuid())
  // Short, human-readable code. Marketplace integrations key off this.
  code      String  @unique
  variantId String  @unique
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // How we plan to satisfy demand for this SKU.
  fulfillment FulfillmentMode

  // --- Made-to-order economics (always populated; null only for pure resold goods we add later) ---
  // Bench time required to print one unit. Lets us later compute lead time
  // and printer capacity without re-modeling.
  printTimeMinutes Int?
  // Filament cost per unit, grams. Cheap proxy for material cost.
  materialGrams    Int?
  // What material we print this in. Free-form for now; promote to enum later.
  material         String?

  // --- In-stock buffer ---
  // Already-printed units sitting on the shelf. The webshop deducts this on
  // checkout. May be zero for pure made-to-order SKUs.
  onHandQty        Int     @default(0)
  // Soft cap: how many we're willing to accept on the made-to-order queue
  // before we mark the SKU unavailable. Null = no cap.
  madeToOrderCap   Int?

  inventoryLedger InventoryEntry[]
  orderItems      OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FulfillmentMode {
  // Printed only after the order comes in.
  made_to_order
  // Buffer printed ahead; ship from shelf.
  in_stock
  // Both: ship from shelf if onHandQty > 0, else queue a print.
  hybrid
}

// Append-only inventory ledger. Every change to onHandQty must be reflected
// here so we can audit "where did this unit come from / go to". Read by the
// admin path; written by the order pipeline (later issues).
model InventoryEntry {
  id        String   @id @default(cuid())
  skuId     String
  sku       Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)
  // Positive = stock added (print finished, restock).
  // Negative = stock removed (order shipped, scrap).
  deltaQty  Int
  reason    InventoryReason
  note      String?
  createdAt DateTime @default(now())

  @@index([skuId, createdAt])
}

enum InventoryReason {
  restock
  order_reserved
  order_shipped
  scrap
  manual_adjustment
}

// Order is the unit of demand. Every paid order — webshop or marketplace —
// lands here. `source` records which surface produced it; `externalId` is
// that surface's own order identifier (Stripe payment intent, Etsy receipt
// id, eBay sale id). The pair `(source, externalId)` is unique so we can
// safely re-run an ingest without creating duplicates.
model Order {
  id          String      @id @default(cuid())
  source      OrderSource
  // The originating surface's order id (Etsy receipt id, Stripe PI, etc).
  externalId  String
  status      OrderStatus @default(pending)

  // Buyer + shipping. We collect the minimum needed to fulfill the order.
  // shippingAddress is a JSON blob so each marketplace can keep its own
  // address shape without forcing a normalized table before we have a
  // shipping integration to consume it.
  buyerEmail      String
  buyerName       String?
  shippingAddress Json    @default("{}")

  // Money is recorded in minor units. We trust the source's totals on
  // ingest; reconciliation against line items is a later concern.
  totalCents Int
  currency   String @default("USD")

  placedAt   DateTime
  notes      String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, externalId])
  @@index([source, placedAt])
}

enum OrderSource {
  webshop
  etsy
  ebay
}

enum OrderStatus {
  pending
  paid
  printing
  shipped
  cancelled
  refunded
}

// One line on an order. Always points at a SKU so the print queue and the
// inventory ledger can both key off it. unitPriceCents snapshots the price
// the buyer actually paid (catalog prices change; orders don't).
model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  order         Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId         String
  sku           Sku    @relation(fields: [skuId], references: [id])
  quantity      Int
  unitPriceCents Int

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([skuId])
}
